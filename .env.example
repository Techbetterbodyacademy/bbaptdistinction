# BBA Coaching App — environment variables
# Copy this file to .env.local for local dev, or set these in Vercel project settings for prod.

# Supabase project (Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — only used server-side for admin operations (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for magic-link callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
